{
  "name": "@breedware/global-utility",
  "version": "1.0.0",
  "description": "Universal utilities for Breedware services (Firebase & React)",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && npm run build:esm && npm run build:cjs",
    "build:esm": "tsc -p tsconfig.json",
    "build:cjs": "tsc -p tsconfig.cjs.json && mv dist/index.js dist/index.cjs"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "Breedware",
  "license": "ISC"
}
