{
  "compilerOptions": {
    "types": ["node"],
    /* Basic Options */
    "target": "ES2022",                          /* Modern Node.js environments (like Node 20/22/24) */
    "module": "NodeNext",                        /* Best for modern ESM or CJS compatibility */
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "declaration": true,                         /* Generates .d.ts files for IntelliSense */
    "declarationMap": true,                      /* Helps with "Go to Definition" in VS Code */
    "sourceMap": true,                           /* Helps with debugging */
    "outDir": "./dist",                          /* Redirect output to the dist folder */
    "rootDir": "./src",                          /* Ensure the structure inside dist matches src */
    "removeComments": false,                     /* Keep comments for better library documentation */

    /* Strict Type-Checking Options */
    "strict": true,                              /* Enable all strict type-checking options */
    "noImplicitAny": true,                       /* Raise error on expressions with 'any' type */
    "strictNullChecks": true,                    /* Ensure null/undefined are handled */

    /* Module Resolution Options */
    "esModuleInterop": true,                     /* Enables emit interoperability between CommonJS and ES Modules */
    "forceConsistentCasingInFileNames": true,    /* Disallow inconsistently-cased references to the same file */

    /* Advanced Options */
    "skipLibCheck": true                         /* Skip type checking of declaration files (.d.ts) */
  },
  "include": ["src"],                       /* Only compile files in the src folder */
  "exclude": ["node_modules", "dist", "**/*.spec.ts"] /* Don't compile tests or previous builds */
}